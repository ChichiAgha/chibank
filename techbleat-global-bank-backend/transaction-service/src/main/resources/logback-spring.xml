<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>{"timestamp":"%date{ISO8601}","level":"%level","service":"transaction-service","logger":"%logger{36}","thread":"%thread","message":"%replace(%msg){'"','\\"'}","exception":"%replace(%ex){'[\r\n]+',' | '}"}%n</pattern>
        </encoder>
    </appender>
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>

